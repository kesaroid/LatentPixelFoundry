# =============================================================================
# AI Video Generator - Environment Configuration
# =============================================================================
# Copy to .env and fill in your values. All secrets live here.
#   cp .env.example .env
#
# deploy-worker.sh and infra/worker.conf also read from .env when present.
# =============================================================================

# --- Database ---
POSTGRES_USER=videogen
POSTGRES_PASSWORD=change-me-secure-db-password
POSTGRES_DB=videogen
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# --- Backend ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# --- Worker Authentication ---
# Shared secret between backend and worker (generate a secure random string)
WORKER_API_KEY=change-me-to-a-secure-random-string

# --- Worker ---
# Set to "true" for local M1 development (simulates GPU worker in-process)
MOCK_WORKER=true
MOCK_DELAY_SECONDS=5

# URL of the cloud GPU worker (used when MOCK_WORKER=false)
WORKER_URL=http://localhost:9000/generate

# URL the worker uses to call back to the backend
BACKEND_URL=http://backend:8000

# --- Video Generation Defaults ---
DEFAULT_DURATION=5
DEFAULT_RESOLUTION=720p

# --- Logging ---
LOG_LEVEL=INFO

# --- API Keys (keep secret, never commit .env) ---
# Hugging Face token for model downloads (deploy-worker) and future API use
# Get yours at: https://huggingface.co/settings/tokens
HUGGING_FACE_API_KEY=

# --- Deploy (GPU worker EC2) - optional overrides ---
# deploy-worker.sh reads .env first; infra/worker.conf can override
# AWS_REGION=us-east-1
# INSTANCE_TYPE=g5.xlarge
# KEY_NAME=lpf-worker-key
# MODELS_S3_URI=
