#
# For local testing: copy ../LatentPixelFoundry/.env.example to ../LatentPixelFoundry/.env
# For deploy: deploy-worker.sh copies LatentPixelFoundry/.env to the remote.
#
# Required vars for worker: WORKER_API_KEY, BACKEND_URL
